# ScholarAgents local environment example
# Copy this file to `.env` for local testing, then fill in your real credentials.

# Default provider:
# - use `mock` for local development with no external API calls
# - use `openai` for OpenAI-compatible providers such as OpenAI or DeepSeek
MODEL_PROVIDER=mock

# Mock provider settings
MOCK_MODEL_NAME=mock-default

# OpenAI-compatible provider settings
# For OpenAI official API, you can usually leave OPENAI_BASE_URL empty.
# For DeepSeek OpenAI-compatible mode, use:
# OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.4

# Optional: if you want to remember an alternative reasoning model name locally
# without wiring it into the current code path yet, keep it here for reference.
DEEPSEEK_REASONING_MODEL=deepseek-reasoner

# Generation controls
MODEL_TEMPERATURE=0.2
MODEL_MAX_OUTPUT_TOKENS=600
MODEL_TIMEOUT=30
MODEL_TOP_P=1.0
MODEL_FALLBACK_TO_MOCK=true
MODEL_USE_CACHE=false
